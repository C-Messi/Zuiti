node_modules
dist
out
release
.DS_Store
.eslintcache
*.log*
.env

# TypeScript build artifacts
*.tsbuildinfo
electron.vite.config.js
electron.vite.config.d.ts

# Compiled JS/d.ts alongside source .ts (main/preload/shared)
src/**/*.js
src/**/*.d.ts
!src/renderer/src/env.d.ts

# Internal docs
DEMO.md

# Runtime adaptive state
# SOUL.md is project persona source; generated long-term memory stays local.
memory/*
!memory/
!memory/SOUL.md
!memory/memory.example.md

# Runtime-generated SVG action skills stay local.
# Keep one curated example package for contributors.
skills/*
!skills/
!skills/.gitkeep
!skills/example-soft-wave/
!skills/example-soft-wave/**
